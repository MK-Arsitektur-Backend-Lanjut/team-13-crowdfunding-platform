{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "stress:read": "npx artillery run stress-test/artillery/read-heavy.yml",
        "stress:write": "npx artillery run stress-test/artillery/write-heavy.yml",
        "stress:mixed": "npx artillery run stress-test/artillery/mixed-70r-30w.yml",
        "stress:quick": "npx artillery quick --count 20 --num 25 http://localhost:8000/api/campaigns",
        "stress:campaign:quick": "npx artillery run stress-test/artillery/campaign-smoke.yml",
        "stress:warmup": "npx artillery run stress-test/artillery/warmup-only.yml",
        "stress:campaign:medium": "npx artillery run stress-test/artillery/medium-campaign.yml",
        "stress:campaign:medium:full": "npm run stress:warmup && npm run stress:campaign:medium",
        "stress:campaign:read": "npx artillery run stress-test/artillery/campaign-read-heavy.yml",
        "stress:campaign": "npm run stress:campaign:quick && npm run stress:campaign:medium && npm run stress:campaign:read"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "artillery": "^2.0.33",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
